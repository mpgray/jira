# Jira Configuration
# Your Jira instance URL
JIRA_URL=https://your-domain.atlassian.net

# Your Jira email address
JIRA_EMAIL=your-email@example.com

# Your Jira API token (generate at: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your_api_token_here

# Sprint Configuration
# Leave empty or comment out to automatically use the current active sprint (RECOMMENDED)
# Set to a specific sprint name only if you need to override
# SPRINT_NAME=Sprint 23

# Frequent Time Log Tickets
# Set these to the ticket keys you commonly log time against.
# Any entry left unset will simply not appear in the quick-select list.
# TICKET_STAND_UP=PROJECT-001
# TICKET_SPRINT_PLANNING=PROJECT-002
# TICKET_SPRINT_RETRO=PROJECT-003
# TICKET_SPRINT_REFINEMENT=PROJECT-004
# TICKET_SPRINT_REVIEW=PROJECT-005
# TICKET_REGRESSION_REVIEW=PROJECT-006

# Timesheet URL (optional)
# If your Jira instance has a timesheet plugin, set the full URL here.
# JIRA_TIMESHEET_URL=https://your-domain.atlassian.net/plugins/servlet/ac/your-plugin/timesheet
